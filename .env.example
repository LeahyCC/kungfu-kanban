# Postgres — install the Neon integration on the Vercel project (Storage tab)
DATABASE_URL=

# 32-byte hex key for encrypting stored provider API keys: `openssl rand -hex 32`
APP_ENCRYPTION_KEY=

# Clerk — install the Clerk integration on the Vercel project to enable real
# multi-user auth. Until these are set, the app runs as a single demo tenant.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cron auth — required for /api/cron/sweep (which finalizes long repo runs and
# recovers stranded tasks). The route fails closed without it. Vercel Cron sends
# `Authorization: Bearer $CRON_SECRET` automatically. `openssl rand -hex 32`
CRON_SECRET=

# Billing (optional) — set these to turn on paid plans. Without them the app is
# in free beta and every tenant gets Pro-level entitlements.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_WEBHOOK_SECRET=
# Public origin, used to build Stripe redirect URLs (defaults to the request origin)
NEXT_PUBLIC_APP_URL=

# Cost controls — sandbox minutes are the app's main operating cost.
# Per-run sandbox lifetime in minutes (clamped 5..45, default 20)
SANDBOX_MAX_MINUTES=20
# Per-tenant repo runs per day on Pro/beta (default 30)
REPO_RUNS_PER_DAY=30
