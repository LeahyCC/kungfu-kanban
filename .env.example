# Postgres — install the Neon integration on the Vercel project (Storage tab)
DATABASE_URL=

# 32-byte hex key for encrypting stored provider API keys: `openssl rand -hex 32`
APP_ENCRYPTION_KEY=

# Clerk — install the Clerk integration on the Vercel project to enable real
# multi-user auth. Until these are set, the app runs as a single demo tenant.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
